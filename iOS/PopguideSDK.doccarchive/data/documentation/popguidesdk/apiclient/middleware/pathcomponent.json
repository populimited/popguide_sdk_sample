{"hierarchy":{"paths":[["doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK","doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/ApiClient","doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/ApiClient\/Middleware"]]},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/ApiClient\/Middleware\/pathComponent"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/popguidesdk\/apiclient\/middleware\/pathcomponent"]}],"metadata":{"modules":[{"name":"PopguideSDK"}],"symbolKind":"property","roleHeading":"Instance Property","externalID":"s:11PopguideSDK9ApiClientC10MiddlewareV13pathComponentSSvp","title":"pathComponent","fragments":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"pathComponent"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:SS","text":"String"}],"role":"symbol"},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["iOS"],"tokens":[{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"pathComponent"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:SS","text":"String","kind":"typeIdentifier"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"Examples:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"pathComponent","type":"codeVoice"},{"type":"text","text":" is “user”, the middleware is applied only to requests"},{"type":"text","text":" "},{"type":"text","text":"that include “\/user” in their URL path, such as “https:\/\/example.com\/api\/user” or “https:\/\/example.com\/api\/user\/details”."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If "},{"code":"pathComponent","type":"codeVoice"},{"type":"text","text":" is “\/v1”, the middleware targets requests with “\/v1” in their path,"},{"type":"text","text":" "},{"type":"text","text":"like “https:\/\/example.com\/api\/v1\/products” or “https:\/\/example.com\/api\/v1\/users\/123”."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Using “\/” as "},{"code":"pathComponent","type":"codeVoice"},{"type":"text","text":" means the middleware applies to every request, regardless of its path."},{"type":"text","text":" "},{"type":"text","text":"This is useful for applying global behaviors, such as logging all requests or adding common headers"},{"type":"text","text":" "},{"type":"text","text":"to every request made by the application."}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"text","text":"This targeted application makes it possible to layer middleware based on URL structure, enabling"},{"type":"text","text":" "},{"text":"fine-grained control over request modification and response handling based on specific endpoints or services.","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","abstract":[{"type":"text","text":"Path components are the segments in the URL after the domain, separated by “\/”. For example, in the URL “https:\/\/example.com\/v1\/user”, the path components are “v1” and “user”."},{"type":"text","text":" "},{"type":"text","text":"If you specify the path component as “\/”, the middleware will be applied to every API call, regardless of its specific path."}],"references":{"doc://popguide-sdk-ios.PopguideSDK/documentation/PopguideSDK/ApiClient":{"role":"symbol","identifier":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/ApiClient","type":"topic","kind":"symbol","title":"ApiClient","navigatorTitle":[{"text":"ApiClient","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ApiClient","kind":"identifier"}],"abstract":[],"url":"\/documentation\/popguidesdk\/apiclient"},"doc://popguide-sdk-ios.PopguideSDK/documentation/PopguideSDK/ApiClient/Middleware/pathComponent":{"type":"topic","title":"pathComponent","fragments":[{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"pathComponent","kind":"identifier"},{"text":": ","kind":"text"},{"text":"String","kind":"typeIdentifier","preciseIdentifier":"s:SS"}],"identifier":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/ApiClient\/Middleware\/pathComponent","url":"\/documentation\/popguidesdk\/apiclient\/middleware\/pathcomponent","kind":"symbol","role":"symbol","abstract":[{"text":"Path components are the segments in the URL after the domain, separated by “\/”. For example, in the URL “https:\/\/example.com\/v1\/user”, the path components are “v1” and “user”.","type":"text"},{"text":" ","type":"text"},{"text":"If you specify the path component as “\/”, the middleware will be applied to every API call, regardless of its specific path.","type":"text"}]},"doc://popguide-sdk-ios.PopguideSDK/documentation/PopguideSDK/ApiClient/Middleware":{"type":"topic","url":"\/documentation\/popguidesdk\/apiclient\/middleware","kind":"symbol","title":"ApiClient.Middleware","abstract":[{"text":"Represents a middleware component that can be applied to network requests and responses.","type":"text"},{"text":" ","type":"text"},{"text":"This struct defines a middleware with a unique identifier, target URL path component,","type":"text"},{"text":" ","type":"text"},{"text":"a callback closure to execute, and specifies whether it should be applied before the request is sent","type":"text"},{"text":" ","type":"text"},{"text":"or after the response is received.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"Middleware"}],"role":"symbol","identifier":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/ApiClient\/Middleware","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Middleware"}]},"doc://popguide-sdk-ios.PopguideSDK/documentation/PopguideSDK":{"role":"collection","identifier":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK","type":"topic","kind":"symbol","title":"PopguideSDK","abstract":[],"url":"\/documentation\/popguidesdk"}}}