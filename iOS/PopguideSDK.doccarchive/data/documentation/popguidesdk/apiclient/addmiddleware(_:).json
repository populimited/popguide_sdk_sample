{"hierarchy":{"paths":[["doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK","doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/ApiClient"]]},"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/ApiClient\/addMiddleware(_:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/popguidesdk\/apiclient\/addmiddleware(_:)"]}],"metadata":{"modules":[{"name":"PopguideSDK"}],"extendedModule":"PopguideSDK","roleHeading":"Instance Method","symbolKind":"method","externalID":"s:11PopguideSDK9ApiClientC13addMiddlewareyyAA0F8Protocol_pF","title":"addMiddleware(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"addMiddleware"},{"kind":"text","text":"("},{"kind":"keyword","text":"any"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:11PopguideSDK18MiddlewareProtocolP","text":"MiddlewareProtocol"},{"kind":"text","text":")"}],"role":"symbol"},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"addMiddleware"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"middleware"},{"kind":"text","text":": "},{"kind":"keyword","text":"any"},{"kind":"text","text":" "},{"identifier":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/MiddlewareProtocol","kind":"typeIdentifier","preciseIdentifier":"s:11PopguideSDK18MiddlewareProtocolP","text":"MiddlewareProtocol"},{"kind":"text","text":")"}]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"text":"The ","type":"text"},{"code":"Middleware","type":"codeVoice"},{"text":" instance encapsulating the path component target, pre-request callback, and post-response callback.","type":"text"}],"type":"paragraph"}],"name":"middleware"}],"kind":"parameters"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A URL path component is a segment of the URL that follows the domain name, separated by “\/”. For instance, in “https:\/\/example.com\/v1\/user”, the segments “v1” and “user” are path components."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Specifying the path component as “\/” allows the middleware to intercept every API call, applying global modifications or behaviors. This feature facilitates the application of diverse middleware logic on a per-path-segment basis, enabling precise control over request and response handling for different API endpoints."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It’s possible to associate multiple middleware with the same path component. They execute sequentially in the order they were added, enabling layered modifications or behaviors for the same URL path segment."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this function to attach middleware for intercepting requests matching a specific URL path component. The middleware can perform various operations such as modifying requests before they’re sent or processing responses after they’re received."}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Example:"}],"type":"paragraph"},{"syntax":null,"code":["let userPreRequestMiddleware = Middleware(pathComponent: \"user\", preRequestCallbak: { request in","    \/\/ Modify the request, e.g., add a specific header","    var headers = request.allHTTPHeaderFields ?? [:]","    headers[\"Authorization\"] = \"Bearer token\"","    request.allHTTPHeaderFields = headers","}, postResponseCallbak: { response in","    \/\/ Process the response, e.g., logging or error handling","})","","apiClient.addMiddleware(userPreRequestMiddleware)","","let globalMiddleware = Middleware(pathComponent: \"\/\", preRequestCallbak: { request in","    \/\/ Applies to every API call","    var headers = request.allHTTPHeaderFields ?? [:]","    headers[\"App-Version\"] = \"1.0.0\"","    request.allHTTPHeaderFields = headers","}, postResponseCallbak: { response in","    \/\/ Global response handling","})","","apiClient.addMiddleware(globalMiddleware)"],"type":"codeListing"}]}],"type":"unorderedList"}],"kind":"content"}],"kind":"symbol","abstract":[{"type":"text","text":"Registers a middleware to intercept and modify requests and responses based on a specific URL path component."}],"references":{"doc://popguide-sdk-ios.PopguideSDK/documentation/PopguideSDK/ApiClient/addMiddleware(_:)":{"identifier":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/ApiClient\/addMiddleware(_:)","type":"topic","url":"\/documentation\/popguidesdk\/apiclient\/addmiddleware(_:)","title":"addMiddleware(_:)","kind":"symbol","abstract":[{"type":"text","text":"Registers a middleware to intercept and modify requests and responses based on a specific URL path component."}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addMiddleware","kind":"identifier"},{"text":"(","kind":"text"},{"text":"any","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:11PopguideSDK18MiddlewareProtocolP","text":"MiddlewareProtocol","kind":"typeIdentifier"},{"text":")","kind":"text"}],"role":"symbol"},"doc://popguide-sdk-ios.PopguideSDK/documentation/PopguideSDK/MiddlewareProtocol":{"identifier":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/MiddlewareProtocol","type":"topic","url":"\/documentation\/popguidesdk\/middlewareprotocol","navigatorTitle":[{"text":"MiddlewareProtocol","kind":"identifier"}],"title":"MiddlewareProtocol","kind":"symbol","abstract":[],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MiddlewareProtocol","kind":"identifier"}],"role":"symbol"},"doc://popguide-sdk-ios.PopguideSDK/documentation/PopguideSDK":{"role":"collection","identifier":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK","type":"topic","kind":"symbol","title":"PopguideSDK","abstract":[],"url":"\/documentation\/popguidesdk"},"doc://popguide-sdk-ios.PopguideSDK/documentation/PopguideSDK/ApiClient":{"role":"symbol","identifier":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/ApiClient","type":"topic","kind":"symbol","title":"ApiClient","navigatorTitle":[{"text":"ApiClient","kind":"identifier"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ApiClient","kind":"identifier"}],"abstract":[],"url":"\/documentation\/popguidesdk\/apiclient"}}}