{"sections":[],"abstract":[{"text":"Registers a middleware to intercept and modify requests and responses based on a specific URL path component.","type":"text"}],"metadata":{"roleHeading":"Instance Method","role":"symbol","symbolKind":"method","extendedModule":"PopguideSDK","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"addMiddleware"},{"kind":"text","text":"("},{"kind":"keyword","text":"any"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:11PopguideSDK18MiddlewareProtocolP","text":"MiddlewareProtocol"},{"kind":"text","text":")"}],"title":"addMiddleware(_:)","modules":[{"name":"PopguideSDK"}],"externalID":"s:11PopguideSDK9ApiClientC13addMiddlewareyyAA0F8Protocol_pF"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/popguidesdk\/apiclient\/addmiddleware(_:)"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["iOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"addMiddleware"},{"text":"(","kind":"text"},{"kind":"externalParam","text":"_"},{"text":" ","kind":"text"},{"text":"middleware","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"any","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:11PopguideSDK18MiddlewareProtocolP","identifier":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/MiddlewareProtocol","text":"MiddlewareProtocol","kind":"typeIdentifier"},{"text":")","kind":"text"}]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"Middleware","type":"codeVoice"},{"text":" instance encapsulating the path component target, pre-request callback, and post-response callback.","type":"text"}]}],"name":"middleware"}]},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A URL path component is a segment of the URL that follows the domain name, separated by “\/”. For instance, in “https:\/\/example.com\/v1\/user”, the segments “v1” and “user” are path components."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Specifying the path component as “\/” allows the middleware to intercept every API call, applying global modifications or behaviors. This feature facilitates the application of diverse middleware logic on a per-path-segment basis, enabling precise control over request and response handling for different API endpoints."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It’s possible to associate multiple middleware with the same path component. They execute sequentially in the order they were added, enabling layered modifications or behaviors for the same URL path segment."}]},{"type":"paragraph","inlineContent":[{"text":"Use this function to attach middleware for intercepting requests matching a specific URL path component. The middleware can perform various operations such as modifying requests before they’re sent or processing responses after they’re received.","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Example:"}]},{"type":"codeListing","syntax":null,"code":["let userPreRequestMiddleware = Middleware(pathComponent: \"user\", preRequestCallbak: { request in","    \/\/ Modify the request, e.g., add a specific header","    var headers = request.allHTTPHeaderFields ?? [:]","    headers[\"Authorization\"] = \"Bearer token\"","    request.allHTTPHeaderFields = headers","}, postResponseCallbak: { response in","    \/\/ Process the response, e.g., logging or error handling","})","","apiClient.addMiddleware(userPreRequestMiddleware)","","let globalMiddleware = Middleware(pathComponent: \"\/\", preRequestCallbak: { request in","    \/\/ Applies to every API call","    var headers = request.allHTTPHeaderFields ?? [:]","    headers[\"App-Version\"] = \"1.0.0\"","    request.allHTTPHeaderFields = headers","}, postResponseCallbak: { response in","    \/\/ Global response handling","})","","apiClient.addMiddleware(globalMiddleware)"]}]}]}],"kind":"content"}],"kind":"symbol","identifier":{"url":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/ApiClient\/addMiddleware(_:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK","doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/ApiClient"]]},"references":{"doc://popguide-sdk-ios.PopguideSDK/documentation/PopguideSDK":{"type":"topic","identifier":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK","abstract":[],"role":"collection","url":"\/documentation\/popguidesdk","kind":"symbol","title":"PopguideSDK"},"doc://popguide-sdk-ios.PopguideSDK/documentation/PopguideSDK/ApiClient":{"kind":"symbol","type":"topic","identifier":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/ApiClient","title":"ApiClient","abstract":[],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"ApiClient"}],"url":"\/documentation\/popguidesdk\/apiclient","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"ApiClient"}]},"doc://popguide-sdk-ios.PopguideSDK/documentation/PopguideSDK/MiddlewareProtocol":{"kind":"symbol","type":"topic","identifier":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/MiddlewareProtocol","title":"MiddlewareProtocol","abstract":[],"role":"symbol","navigatorTitle":[{"text":"MiddlewareProtocol","kind":"identifier"}],"url":"\/documentation\/popguidesdk\/middlewareprotocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"MiddlewareProtocol"}]},"doc://popguide-sdk-ios.PopguideSDK/documentation/PopguideSDK/ApiClient/addMiddleware(_:)":{"abstract":[{"type":"text","text":"Registers a middleware to intercept and modify requests and responses based on a specific URL path component."}],"url":"\/documentation\/popguidesdk\/apiclient\/addmiddleware(_:)","title":"addMiddleware(_:)","role":"symbol","type":"topic","identifier":"doc:\/\/popguide-sdk-ios.PopguideSDK\/documentation\/PopguideSDK\/ApiClient\/addMiddleware(_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"addMiddleware","kind":"identifier"},{"text":"(","kind":"text"},{"text":"any","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MiddlewareProtocol","preciseIdentifier":"s:11PopguideSDK18MiddlewareProtocolP","kind":"typeIdentifier"},{"text":")","kind":"text"}],"kind":"symbol"}}}